# KontextMind Environment Configuration
# Copy this to .env for local development

# ===========================================
# Server Configuration
# ===========================================
PORT=7331
HOST=0.0.0.0
DATA_DIR=/kontextmind/projects

# ===========================================
# Authentication
# ===========================================
API_KEY=your-api-key-here

# GitHub token for cloning repositories (optional)
GITHUB_TOKEN=

# ===========================================
# LLM Configuration
# These are used by the container entrypoint to
# configure the global LLM provider automatically
# ===========================================

# LLM Provider Name (used as the global config name)
# Default: opusmax
LLM_PROVIDER_NAME=opusmax

# LLM Provider Type
# Options: openai, anthropic, ollama, bedrock, openai-compatible
# Default: openai-compatible
LLM_PROVIDER=openai-compatible

# API Key for your LLM provider (required for Ask functionality)
LLM_API_KEY=

# Base URL for OpenAI-compatible providers
# For Anthropic: https://api.anthropic.com
# For OpenAI: https://api.openai.com/v1
# Default: https://api.anthropic.com
LLM_BASE_URL=https://api.anthropic.com

# Model name
# For Anthropic Opus: claude-opus-4-7
# For Anthropic Sonnet: claude-sonnet-4-6
# For OpenAI: gpt-4o, gpt-4o-mini
# Default: claude-opus-4-7
LLM_MODEL=claude-opus-4-7

# ===========================================
# Production Only
# ===========================================
# Data path for persistent storage (production)
# DATA_PATH=./data