{
  "name": "@kontextmind/cli",
  "version": "0.1.0",
  "description": "KontextMind CLI - Initialize and manage project memory for AI coding agents",
  "type": "module",
  "bin": {
    "kontextmind": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@kontextmind/core": "workspace:*",
    "@kontextmind/mcp": "workspace:*",
    "chalk": "^5.3.0",
    "commander": "^11.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  }
}
